Bootstrap: docker
From: continuumio/miniconda3
Stage: build

%setup
    mkdir ${SINGULARITY_ROOTFS}/src
    mkdir -p ${SINGULARITY_ROOTFS}/src/rust_utils/target/x86_64-unknown-linux-musl/release
    cp -r ../src/python3 ${SINGULARITY_ROOTFS}/src/
    #cp -r ../src/rust_utils ${SINGULARITY_ROOTFS}/src/
    cp ../src/rust_utils/target/x86_64-unknown-linux-musl/release/evaluate_motifs ${SINGULARITY_ROOTFS}/src/rust_utils/target/x86_64-unknown-linux-musl/release/
    cp ../src/rust_utils/target/x86_64-unknown-linux-musl/release/filter_motifs ${SINGULARITY_ROOTFS}/src/rust_utils/target/x86_64-unknown-linux-musl/release/
    cp ../src/rust_utils/target/x86_64-unknown-linux-musl/release/get_robustness ${SINGULARITY_ROOTFS}/src/rust_utils/target/x86_64-unknown-linux-musl/release/
    cp ../src/rust_utils/target/x86_64-unknown-linux-musl/release/infer_motifs ${SINGULARITY_ROOTFS}/src/rust_utils/target/x86_64-unknown-linux-musl/release/
    chmod -R 755 ${SINGULARITY_ROOTFS}/src

%environment
    export SHAPEME_VER=0.2.7
    export PATH="/opt/conda/envs/motifer/bin:/opt/conda/bin:${PATH}"

%files
    env_spec.yaml
    deepdnashape_env.yaml
    shapeme.bashrc /shapeme.bashrc

%runscript
    /bin/bash -rcfile /shapeme.bashrc

%post
    export PATH="/conda/envs/motifer/bin:/opt/conda/bin:${PATH}" \
    && apt update -y \
    && apt upgrade -y \
    && apt install -y libffi-dev \
    && apt install -y libffi-dev git ca-certificates \
    && conda update -y -n base conda \
    && conda install -c conda-forge mamba \
    && mamba env create -f env_spec.yaml \
    && mamba env create -f deepdnashape_env.yaml \
    && cd /src \
    && git clone https://github.com/JinsenLi/deepDNAshape.git \
    && /opt/conda/envs/deepdnashape/bin/python -m pip install --no-deps ./deepDNAshape \
    && rm -rf /src/deepDNAshape

    CUSTOM_ENV=/.singularity.d/env/99-zz_custom_env.sh
    cat >$CUSTOM_ENV <<EOF
#!/bin/bash
PS1="[shapeme_0.2.7]\w \$"
EOF
    chmod 755 $CUSTOM_ENV

%test
    which python
    source /opt/conda/etc/profile.d/conda.sh
    conda activate motifer
    python -c "import numpy; print(numpy.__file__)"

    echo "motifer python:"
    /opt/conda/envs/motifer/bin/python -c "import sys; print(sys.executable)"

    echo "motifer numpy:"
    /opt/conda/envs/motifer/bin/python -c "import numpy as np; print('motifer numpy', np.__version__); print(np.__file__)"

    echo "deepdnashape python:"
    /opt/conda/envs/deepdnashape/bin/python -c "import sys; print(sys.executable)"

    echo "deepdnashape numpy + tensorflow:"
    /opt/conda/envs/deepdnashape/bin/python -c "import numpy as np; import tensorflow as tf; print('deepdnashape numpy', np.__version__); print('tf', tf.__version__)"

